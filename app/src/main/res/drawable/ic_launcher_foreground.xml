<?xml version="1.0" encoding="utf-8"?>
<!--
  STMNA adaptive icon foreground: V logo centered in safe zone.
  Adaptive icon canvas = 108dp, safe zone = inner 72dp (66%).
  10dp inset keeps the V well within the safe zone across all launcher masks.
-->
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:insetLeft="10dp"
    android:insetTop="10dp"
    android:insetRight="10dp"
    android:insetBottom="10dp">
    <bitmap
        android:src="@drawable/ic_stmna_icon_source"
        android:gravity="fill" />
</inset>
